{
  "model": {
    "vocab_size": 256,
    "tone_vocab_size": 8,
    "hidden_size": 64,
    "intermediate_size": 172,
    "max_seq_len": 128,
    "n_prelude_layers": 1,
    "n_recurrent_layers": 2,
    "n_coda_layers": 1,
    "n_heads": 4,
    "n_kv_heads": 2,
    "head_dim": 64,
    "rope_theta": 50000.0,
    "attn_qk_bias": true,
    "mean_recurrence": 4.0,
    "recurrence_sigma": 0.5,
    "backprop_depth": 3,
    "state_init_std": 1.0,
    "use_moe": true,
    "n_experts": 4,
    "n_experts_active": 2,
    "use_vietnamese_expert": true,
    "moe_aux_loss_coef": 0.01,
    "use_abstention_head": true,
    "abstention_loss_coef": 0.1,
    "use_tone_head": true,
    "tone_loss_coef": 0.5,
    "init_std": 0.02,
    "norm_eps": 1e-05,
    "embedding_scale": true,
    "dropout": 0.0,
    "layerscale_init": 0.1,
    "tie_embeddings": true
  },
  "train": {
    "learning_rate": 0.0004,
    "weight_decay": 0.1,
    "adam_beta1": 0.9,
    "adam_beta2": 0.95,
    "adam_eps": 1e-08,
    "grad_clip": 1.0,
    "warmup_steps": 100,
    "max_steps": 50,
    "min_lr_ratio": 0.1,
    "batch_size": 4,
    "grad_accum_steps": 4,
    "log_interval": 10,
    "eval_interval": 500,
    "save_interval": 1000,
    "use_amp": true,
    "gradient_checkpointing": false,
    "seed": 1337,
    "device": "auto",
    "compile_model": false,
    "out_dir": "checkpoints"
  },
  "data": {
    "data_dir": "data",
    "train_file": "train.bin",
    "val_file": "val.bin",
    "tokenizer_file": "tokenizer.json",
    "stage": "pretrain"
  }
}